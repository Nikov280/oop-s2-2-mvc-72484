@model FoodSafety.Domain.Entities.Inspection

@{
    ViewData["Title"] = "Inspection Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h3 class="mb-0"><i class="bi bi-info-circle me-2"></i>Inspection Details</h3>
                </div>
                <div class="card-body p-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Premises</dt>
                        <dd class="col-sm-8 fw-bold">@Model.Premises?.Name</dd>

                        <dt class="col-sm-4 text-muted">Inspection Date</dt>
                        <dd class="col-sm-8">@Model.InspectionDate.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-4 text-muted">Score</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.Score < 50 ? "bg-danger" : "bg-success") rounded-pill">
                                @Model.Score / 100
                            </span>
                        </dd>

                        <dt class="col-sm-4 text-muted">Outcome</dt>
                        <dd class="col-sm-8">
                            @if (Model.Outcome.ToString() == "Pass")
                            {
                                <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Pass</span>
                            }
                            else
                            {
                                <span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i>Fail</span>
                            }
                        </dd>

                        <dt class="col-sm-4 text-muted">Notes</dt>
                        <dd class="col-sm-8 text-secondary">@(string.IsNullOrEmpty(Model.Notes) ? "No notes available." : Model.Notes)</dd>
                    </dl>
                </div>
                <div class="card-footer bg-light py-3 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>