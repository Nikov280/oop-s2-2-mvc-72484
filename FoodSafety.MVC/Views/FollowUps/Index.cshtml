@model IEnumerable<FoodSafety.MVC.ViewModels.FollowUpIndexViewModel>


@{
    ViewData["Title"] = "Follow-Up Tracker";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-dark">Follow-Up Tracker</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">+ Create New</a>
    </div>

    <div class="card shadow-sm border-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Due Date</th>
                    <th>Premises Name</th> 
                    <th>Status</th>
                    <th>Closed Date</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    
                    <tr class="@(item.IsOverdue ? "table-danger text-danger fw-bold" : "")">
                        <td class="align-middle">
                            @item.DueDate.ToString("dd/MM/yyyy")
                            @if (item.IsOverdue)
                            {
                                <span class="badge bg-danger ms-1">OVERDUE</span>
                            }
                        </td>
                        <td class="align-middle">@item.PremisesName</td>
                        <td class="align-middle">
                            @if (item.Status == "Open")
                            {
                                <span class="badge bg-warning text-dark">Open</span>
                            }
                            else if (item.Status == "Pending")
                            {
                                <span class="badge bg-info text-dark">Pending</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Closed</span>
                            }
                        </td>
                        <td class="align-middle text-muted">
                            @(item.ClosedDate?.ToString("dd/MM/yyyy") ?? "—")
                        </td>
                        <td class="text-center">                            
                            @if (item.Status != "Closed")
                            {
                                <form asp-action="Close" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success">Mark Closed</button>
                                </form>
                            }
                            <div class="btn-group ms-1">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>