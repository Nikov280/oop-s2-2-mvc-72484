@model FoodSafety.Domain.Entities.FollowUp

@{
    ViewData["Title"] = "Delete Confirmation";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3 text-center">
                    <h4 class="mb-0">Are you sure you want to delete this?</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning text-center mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        This action cannot be undone.
                    </div>

                    <div class="list-group list-group-flush">
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-muted">Due Date</span>
                            <span class="fw-bold">@Model.DueDate.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-muted">Status</span>
                            <span class="badge @(Model.Status == "Open" ? "bg-warning text-dark" : "bg-success")">@Model.Status</span>
                        </div>
                        @if (Model.ClosedDate.HasValue)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span class="text-muted">Closed Date</span>
                                <span>@Model.ClosedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-white border-0 py-4">
                    <form asp-action="Delete" class="d-flex justify-content-around">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                        <button type="submit" class="btn btn-danger px-4 shadow-sm">Confirm Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>